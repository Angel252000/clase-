# ═══════════════════════════════════════════════════════
# CREAMY API — Variables de entorno
# ═══════════════════════════════════════════════════════
# 1. Copia este archivo: cp .env.example .env
# 2. Rellena los valores reales
# 3. NUNCA subas el .env a Git
# ═══════════════════════════════════════════════════════

# ── MongoDB ─────────────────────────────────────────────
# Local con Docker:
MONGODB_URI=mongodb://127.0.0.1:27017/creamy
# Atlas (producción):
# MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@cluster0.xxxxx.mongodb.net/creamy

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_string_largo_y_aleatorio_minimo_32_chars

# ── Stripe ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_AQUI_VA_TU_CLAVE_SECRETA

# ── Servidor ────────────────────────────────────────────
PORT=4000
CLIENT_URL=http://localhost:5173
